# AI Pipeline Configuration
# Copy to config.yaml and modify

deepseek:
  api_key: ${DEEPSEEK_API_KEY}
  base_url: https://api.deepseek.com/v1
  model: deepseek-chat
  temperature: 0.7
  max_tokens: 4096

ollama:
  base_url: http://localhost:11434/v1
  model: llama3

paths:
  projects: ~/ai-code-projects
  media: ~/ai-media
  history: ~/.ai-chat-history
